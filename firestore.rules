rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read/write their own user profile, follow functionality, etc.
    // (Assuming existing rules allow read/write to users and trips, keeping them open or basic for now)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
      // Allow others to update following/followers array
      allow update: if request.auth != null; 
    }
    
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // --- CHAT FEATURE RULES ---
    match /chats/{chatId} {
      // Allow read/write if the logged-in user is part of the participant list
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participantIds;
      
      // Allow room creation if the creator includes themselves in the participant list
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantIds;

      match /messages/{messageId} {
        // Inherit permissions from parent room security layout
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds;
      }
    }
  }
}
